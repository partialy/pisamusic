<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- 添加底部弹出动画 -->
    <style name="ActivityAnimation.BottomUp" parent="android:Animation.Activity">
        <item name="android:windowEnterAnimation">@anim/slide_up</item>
        <item name="android:windowExitAnimation">@anim/slide_down</item>
    </style>

    <style name="PmMinimalDialogAnimationStyle" parent="@android:style/Animation.Dialog">
        <item name="android:windowEnterAnimation">@anim/pm_minimal_dialog_enter</item>
        <item name="android:windowExitAnimation">@anim/pm_minimal_dialog_exit</item>
    </style>

    <style name="AppTheme" parent="Theme.MaterialComponents.DayNight">
        <item name="customToolbarBackground">@android:color/white</item>
    </style>

    <style name="CircleShape">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <!-- Keep a base entry to satisfy AAPT style grouping -->
    <style name="ShapeAppearance.Pm" />

    <!-- Some libraries reference @style/ShapeAppearance directly; define a safe alias. -->
    <style name="ShapeAppearance" parent="ShapeAppearance.MaterialComponents" />

    <style name="ShapeAppearance.Pm.Corner12">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>

    <style name="ShapeAppearance.Pm.Circular">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <!-- 设置开关：自定义厚轨道 + 白色内嵌滑块 -->
    <style name="Widget.Pm.SettingsSwitch" parent="Widget.MaterialComponents.CompoundButton.Switch">
        <item name="android:background">@null</item>
        <item name="android:foreground">@null</item>
        <item name="track">@drawable/switch_track</item>
        <item name="android:thumb">@drawable/switch_thumb</item>
        <item name="android:width">40dp</item>
        <item name="android:height">24dp</item>
        <item name="switchMinWidth">40dp</item>
        <item name="thumbTextPadding">0dp</item>
        <item name="backgroundTint">@null</item>
        <item name="rippleColor">@android:color/transparent</item>
        <item name="trackTint">@null</item>
        <item name="thumbTint">@null</item>
        <item name="useMaterialThemeColors">false</item>
    </style>
</resources>
