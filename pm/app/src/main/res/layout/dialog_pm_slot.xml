<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/dialogCard"
    android:layout_width="280dp"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="@color/pm_dialog_background"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    app:strokeColor="@color/pm_dialog_stroke"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <FrameLayout
            android:id="@+id/slotContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            tools:layout_height="160dp" />

        <View
            android:id="@+id/horizontalDivider"
            android:layout_width="match_parent"
            android:layout_height="1px"
            android:background="@color/pm_dialog_divider" />

        <LinearLayout
            android:id="@+id/buttonContainer"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/cancelButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:includeFontPadding="false"
                android:textColor="@color/pm_dialog_cancel"
                android:textSize="14sp"
                android:textStyle="bold"
                tools:text="取消" />

            <View
                android:id="@+id/verticalDivider"
                android:layout_width="1px"
                android:layout_height="match_parent"
                android:background="@color/pm_dialog_divider" />

            <TextView
                android:id="@+id/confirmButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:includeFontPadding="false"
                android:textColor="@color/pm_dialog_confirm"
                android:textSize="14sp"
                android:textStyle="bold"
                tools:text="确认" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
