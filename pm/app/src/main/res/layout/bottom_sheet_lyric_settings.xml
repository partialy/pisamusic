<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingBottom="24dp"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="8dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="12dp"
            android:text="@string/lyric_settings_title"
            android:textAppearance="@style/TextAppearance.Material3.TitleLarge"
            android:textColor="?attr/colorOnSurface" />

        <cn.partialy.pm.ui.widget.PmSwitch
            android:id="@+id/lyricSettingsUseWordLyricSwitch"
            style="@style/Widget.Pm.SettingsSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:text="@string/lyric_settings_use_word_lyric"
            android:textAppearance="@style/TextAppearance.Material3.BodyLarge" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/lyric_settings_font_size"
            android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
            android:textColor="?attr/colorOnSurfaceVariant" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/lyricSettingsFontSizeMinus"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/lyric_settings_decrease"
                android:padding="8dp"
                android:src="@drawable/ic_remove_24dp"
                app:tint="?attr/colorOnSurface" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="92dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="8dp"
                android:hint=""
                app:boxCornerRadiusBottomEnd="20dp"
                app:boxCornerRadiusBottomStart="20dp"
                app:boxCornerRadiusTopEnd="20dp"
                app:boxCornerRadiusTopStart="20dp"
                app:boxStrokeWidth="1dp"
                app:boxStrokeWidthFocused="1dp"
                app:endIconMode="none">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/lyricSettingsFontSizeInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:imeOptions="actionDone"
                    android:inputType="number"
                    android:maxLines="1"
                    android:minHeight="40dp"
                    android:paddingVertical="8dp"
                    android:textAlignment="center"
                    tools:text="16" />
            </com.google.android.material.textfield.TextInputLayout>

            <ImageButton
                android:id="@+id/lyricSettingsFontSizePlus"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/lyric_settings_increase"
                android:padding="8dp"
                android:src="@drawable/ic_add_24dp"
                app:tint="?attr/colorOnSurface" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/lyric_settings_normal_color"
            android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
            android:textColor="?attr/colorOnSurfaceVariant" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="8dp"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/lyricSettingsNormalColorRow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal" />
        </HorizontalScrollView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/lyric_settings_current_color"
            android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
            android:textColor="?attr/colorOnSurfaceVariant" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="8dp"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/lyricSettingsCurrentColorRow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal" />
        </HorizontalScrollView>

        <cn.partialy.pm.ui.widget.PmSwitch
            android:id="@+id/lyricSettingsBoldSwitch"
            style="@style/Widget.Pm.SettingsSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:minHeight="48dp"
            android:text="@string/lyric_settings_current_bold"
            android:textAppearance="@style/TextAppearance.Material3.BodyLarge" />

        <cn.partialy.pm.ui.widget.PmSwitch
            android:id="@+id/lyricSettingsCurrentEnlargedSwitch"
            style="@style/Widget.Pm.SettingsSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:text="@string/lyric_settings_current_enlarged"
            android:textAppearance="@style/TextAppearance.Material3.BodyLarge" />

        <cn.partialy.pm.ui.widget.PmSwitch
            android:id="@+id/lyricSettingsWordScaleSwitch"
            style="@style/Widget.Pm.SettingsSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:text="@string/lyric_settings_word_scale"
            android:textAppearance="@style/TextAppearance.Material3.BodyLarge" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/lyric_settings_current_enlarged_dx"
            android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
            android:textColor="?attr/colorOnSurfaceVariant" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/lyricSettingsCurrentEnlargedDxMinus"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/lyric_settings_decrease"
                android:padding="8dp"
                android:src="@drawable/ic_remove_24dp"
                app:tint="?attr/colorOnSurface" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="92dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="8dp"
                android:hint=""
                app:boxCornerRadiusBottomEnd="20dp"
                app:boxCornerRadiusBottomStart="20dp"
                app:boxCornerRadiusTopEnd="20dp"
                app:boxCornerRadiusTopStart="20dp"
                app:boxStrokeWidth="1dp"
                app:boxStrokeWidthFocused="1dp"
                app:endIconMode="none">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/lyricSettingsCurrentEnlargedDxInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:imeOptions="actionDone"
                    android:inputType="number"
                    android:maxLines="1"
                    android:minHeight="40dp"
                    android:paddingVertical="8dp"
                    android:textAlignment="center"
                    tools:text="4" />
            </com.google.android.material.textfield.TextInputLayout>

            <ImageButton
                android:id="@+id/lyricSettingsCurrentEnlargedDxPlus"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/lyric_settings_increase"
                android:padding="8dp"
                android:src="@drawable/ic_add_24dp"
                app:tint="?attr/colorOnSurface" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/lyric_settings_inactive_opacity"
            android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
            android:textColor="?attr/colorOnSurfaceVariant" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/lyricSettingsOpacityMinus"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/lyric_settings_decrease"
                android:padding="8dp"
                android:src="@drawable/ic_remove_24dp"
                app:tint="?attr/colorOnSurface" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="92dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="8dp"
                android:hint=""
                app:boxCornerRadiusBottomEnd="20dp"
                app:boxCornerRadiusBottomStart="20dp"
                app:boxCornerRadiusTopEnd="20dp"
                app:boxCornerRadiusTopStart="20dp"
                app:boxStrokeWidth="1dp"
                app:boxStrokeWidthFocused="1dp"
                app:endIconMode="none">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/lyricSettingsOpacityInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:imeOptions="actionDone"
                    android:inputType="number"
                    android:maxLines="1"
                    android:minHeight="40dp"
                    android:paddingVertical="8dp"
                    android:textAlignment="center"
                    tools:text="85" />
            </com.google.android.material.textfield.TextInputLayout>

            <ImageButton
                android:id="@+id/lyricSettingsOpacityPlus"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/lyric_settings_increase"
                android:padding="8dp"
                android:src="@drawable/ic_add_24dp"
                app:tint="?attr/colorOnSurface" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/lyric_settings_alignment"
            android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
            android:textColor="?attr/colorOnSurfaceVariant" />

        <RadioGroup
            android:id="@+id/lyricSettingsAlignGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/lyricSettingsAlignStart"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/lyric_settings_align_start" />

            <RadioButton
                android:id="@+id/lyricSettingsAlignCenter"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/lyric_settings_align_center" />

            <RadioButton
                android:id="@+id/lyricSettingsAlignEnd"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/lyric_settings_align_end" />
        </RadioGroup>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/lyric_settings_hint"
            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
            android:textColor="?android:attr/textColorSecondary"
            tools:text="提示" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
