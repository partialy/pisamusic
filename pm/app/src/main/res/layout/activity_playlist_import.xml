<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/playlistImportRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/home_page_bg"
    android:fitsSystemWindows="false"
    android:orientation="vertical">

    <View
        android:id="@+id/playlistImportStatusBarSpacer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@color/home_page_bg" />

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/home_page_bg"
            app:navigationIcon="@drawable/ic_back_24" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/kgLoginScroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/home_page_bg"
        android:fillViewport="true">

        <include
            android:id="@+id/kgLogin"
            layout="@layout/include_playlist_import_kg_login" />
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/bottomPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/home_page_bg"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp">

        <TextView
            android:id="@+id/tvImportHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:lineSpacingMultiplier="1.15"
            android:text="@string/playlist_import_hint_kg_login"
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="14sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStartImport"
            style="@style/Widget.Material3.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:minHeight="48dp"
            android:text="@string/playlist_import_start"
            android:textColor="@android:color/white"
            app:backgroundTint="@color/import_playlist_start_button"
            app:cornerRadius="10dp" />
    </LinearLayout>
</LinearLayout>
