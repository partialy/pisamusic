<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/home_page_bg"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:elevation="2dp"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="8dp">

        <com.google.android.material.imageview.ShapeableImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:scaleType="centerCrop"
            android:src="@mipmap/ic_launcher"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Small" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="@string/drawer_brand_title"
            android:textColor="@color/colorOnBgNormal"
            android:textSize="17sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/drawerScanButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="4dp"
            android:background="@android:color/transparent"
            android:contentDescription="@string/drawer_scan"
            android:padding="8dp"
            android:src="@drawable/ic_qr_scan_24"
            app:tint="@color/text_secondary" />

        <ImageButton
            android:id="@+id/drawerCloseButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@android:color/transparent"
            android:contentDescription="@string/drawer_close"
            android:padding="8dp"
            android:src="@drawable/ic_close_24dp"
            app:tint="@color/text_secondary" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/drawerAccountCapsule"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginVertical="6dp"
        android:background="@drawable/bg_drawer_capsule"
        android:clickable="true"
        android:elevation="1dp"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="10dp"
        android:paddingVertical="12dp">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/drawerAccountAvatar"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_pm_icon"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/drawerAccountTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="登录 / 注册"
                android:textColor="@color/colorOnBgNormal"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/drawerAccountSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="账号登录后自动同步收藏与歌单"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        >

        <LinearLayout
            android:id="@+id/drawerKgCapsule"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:elevation="1dp"
            android:background="@drawable/bg_drawer_capsule"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginHorizontal="16dp"
            android:layout_marginVertical="4dp"
            android:paddingHorizontal="8dp"
            android:paddingVertical="10dp">

            <ImageButton
                android:id="@+id/drawerKgImportPlaylistsButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/drawer_import_kg_playlists_cd"
                android:padding="8dp"
                android:visibility="gone"
                android:src="@drawable/ic_playlist_24"
                app:tint="@color/text_secondary" />

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/drawerKgAvatar"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_pm_icon"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full" />

            <TextView
                android:id="@+id/drawerKgNickname"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/colorOnBgNormal"
                android:textSize="15sp"
                tools:text="酷狗用户" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_drawer_badge_kg"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:text="@string/drawer_badge_kg"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:textStyle="bold"
                tools:ignore="SmallSp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/drawerWyCapsule"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_drawer_capsule"
            android:elevation="1dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginHorizontal="16dp"
            android:layout_marginVertical="4dp"
            android:paddingHorizontal="8dp"
            android:paddingVertical="10dp">

            <ImageButton
                android:id="@+id/drawerWyImportPlaylistsButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/drawer_import_wy_playlists_cd"
                android:padding="8dp"
                android:visibility="gone"
                android:src="@drawable/ic_playlist_24"
                app:tint="@color/text_secondary" />

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/drawerWyAvatar"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_pm_icon"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full" />

            <TextView
                android:id="@+id/drawerWyNickname"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/colorOnBgNormal"
                android:textSize="15sp"
                tools:text="网易用户" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_drawer_badge_wy"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:text="@string/drawer_badge_wy"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:textStyle="bold"
                tools:ignore="SmallSp" />
        </LinearLayout>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/drawerMiddleArea"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:minHeight="0dp">

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/transparent" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/drawerMoreMenuCard"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="8dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/home_mini_player_bg"
            app:cardCornerRadius="10dp"
            >

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingVertical="4dp">

                <TextView
                    android:id="@+id/drawerMoreRowKg"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="true"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="10dp"
                    android:text="@string/drawer_more_login_kg"
                    android:textColor="@color/colorOnBgNormal"
                    android:textSize="13sp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginHorizontal="10dp"
                    android:background="#14000000" />

                <TextView
                    android:id="@+id/drawerMoreRowWyWeb"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="true"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="10dp"
                    android:text="@string/drawer_more_login_wy_web"
                    android:textColor="@color/colorOnBgNormal"
                    android:textSize="13sp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginHorizontal="10dp"
                    android:background="#14000000" />

                <TextView
                    android:id="@+id/drawerMoreRowWyApi"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="true"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="10dp"
                    android:text="@string/drawer_more_login_wy_api"
                    android:textColor="@color/colorOnBgNormal"
                    android:textSize="13sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </FrameLayout>

    <LinearLayout
        android:id="@+id/drawerBottomBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingTop="4dp"
        android:paddingBottom="12dp">

        <LinearLayout
            android:id="@+id/drawerSettingsButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/bg_drawer_bottom_pill_ripple"
            android:elevation="1dp"
            android:layout_marginVertical="4dp"
            android:layout_marginHorizontal="4dp"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_settings_24"
                app:tint="@color/text_secondary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="@string/settings"
                android:textColor="@color/colorOnBgNormal"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/drawerMoreButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:elevation="1dp"
            android:layout_marginVertical="4dp"
            android:layout_marginHorizontal="4dp"
            android:background="@drawable/bg_drawer_bottom_pill_ripple"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_apps_grid_24"
                app:tint="@color/text_secondary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="@string/drawer_more"
                android:textColor="@color/colorOnBgNormal"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
