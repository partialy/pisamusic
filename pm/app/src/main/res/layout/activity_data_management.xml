<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/dataManagementRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/home_page_bg"
    android:fitsSystemWindows="false"
    android:orientation="vertical">

    <View
        android:id="@+id/statusBarSpacer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@color/home_page_bg" />

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/home_page_bg"
            app:navigationIcon="@drawable/ic_back_24"
            app:title="@string/settings_data_management" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <include
                android:id="@+id/cardDataOverview"
                layout="@layout/include_data_management_card" />

            <include
                android:id="@+id/cardDataExport"
                layout="@layout/include_data_management_card" />

            <include
                android:id="@+id/cardDataImport"
                layout="@layout/include_data_management_card" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
