<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/localMusicRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/home_page_bg"
    android:fitsSystemWindows="false"
    android:orientation="vertical">

    <!-- 与 Toolbar 同色，铺满状态栏区域，避免 edge-to-edge 下状态栏与顶栏色差 -->
    <View
        android:id="@+id/localMusicStatusBarSpacer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@color/home_page_bg" />

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/home_page_bg"
            android:theme="@style/Theme.Pm"
            app:popupTheme="@style/ThemeOverlay.AppCompat.Light"
            >
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                >
                <TextView
                    android:id="@+id/mine_music"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="@string/mine"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="18sp"
                    />

                <Space
                    android:layout_width="20dp"
                    android:layout_height="match_parent"
                    />

                <TextView
                    android:id="@+id/download_music"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="@string/download"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="18sp"
                    />

            </LinearLayout>

        </androidx.appcompat.widget.Toolbar>

    </com.google.android.material.appbar.AppBarLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="30dp"
        android:gravity="center_horizontal"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        >
        <ImageButton
            android:id="@+id/btn_play_all"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/play_all"
            android:src="@drawable/ic_play_24"
            app:tint="@color/primary" />

        <TextView
            android:id="@+id/songCountTextView"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center"
            android:layout_marginStart="8dp"
            android:text="@string/play_all"
            />

        <Space
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            />

        <ImageButton
            android:id="@+id/search"
            android:layout_width="48dp"
            android:layout_height="match_parent"
            android:layout_gravity="end"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/search"
            android:padding="6dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_search_24"
            android:layout_marginStart="4dp"
            android:alpha="0.8"
            app:tint="?attr/colorOnSurface" />

        <ImageButton
            android:id="@+id/btn_edit_local"
            android:layout_width="48dp"
            android:layout_height="match_parent"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/local_music_edit"
            android:padding="6dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_edit_24"
            android:alpha="0.8"
            app:tint="?attr/colorOnSurface" />
    </LinearLayout>

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior" />


</LinearLayout> 