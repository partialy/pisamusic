<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/playerRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/blurredBgImageView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@null"
        android:scaleType="centerCrop" />

    <View
        android:id="@+id/bgScrim"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/contentLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Header Bar -->
        <LinearLayout
            android:id="@+id/headerBar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:minHeight="56dp"
            android:orientation="horizontal"
            android:paddingHorizontal="4dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageButton
                android:id="@+id/collapseButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/cancel"
                android:padding="12dp"
                android:src="@drawable/ic_arrow_down_24"
                app:tint="@android:color/white" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/songTitleTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="@string/song_name"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="8dp">

                    <TextView
                        android:id="@+id/artistTextView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:gravity="center_vertical"
                        android:maxLines="1"
                        android:text="@string/singer"
                        android:textColor="#B0B0B0"
                        android:textSize="13sp"
                        app:layout_constrainedWidth="true"
                        app:layout_constraintEnd_toStartOf="@id/songSourceTagTextView"
                        app:layout_constraintHorizontal_bias="0.5"
                        app:layout_constraintHorizontal_chainStyle="packed"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/songSourceTagTextView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="3dp"
                        android:visibility="gone"
                        app:layout_constraintBottom_toBottomOf="@id/artistTextView"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/artistTextView"
                        app:layout_constraintTop_toTopOf="@id/artistTextView" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </LinearLayout>

            <ImageButton
                android:id="@+id/moreButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/more"
                android:padding="12dp"
                android:src="@drawable/ic_more_vert_24"
                app:tint="@android:color/white" />
        </LinearLayout>

        <!-- Lyrics -->
        <FrameLayout
            android:id="@+id/lyricsContainer"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="10dp"
            app:layout_constraintBottom_toTopOf="@id/actionRow"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/headerBar">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/lyricsRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingHorizontal="36dp"
                android:clipToPadding="false"
                android:overScrollMode="never" />

            <cn.partialy.pm.ui.player.KaraokeLyricsView
                android:id="@+id/karaokeLyricsView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingHorizontal="72dp"
                android:paddingVertical="16dp"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/lyricCenterSeekOverlay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_marginHorizontal="8dp"
                android:background="@drawable/bg_lyric_center_seek_overlay"
                android:clickable="true"
                android:contentDescription="@string/lyric_seek_from_line"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="4dp"
                android:paddingVertical="4dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/lyricCenterSeekTimeText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:textColor="#CCFFFFFF"
                    android:layout_marginStart="8dp"
                    android:textSize="11sp" />

                <Space
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="match_parent"
                    />

                <ImageButton
                    android:id="@+id/lyricCenterSeekButton"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@android:color/transparent"
                    android:clickable="false"
                    android:contentDescription="@null"
                    android:focusable="false"
                    android:padding="8dp"
                    android:src="@drawable/ic_play_24"
                    app:tint="#CCFFFFFF" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/listenTogetherChip"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_gravity="top|center_horizontal"
                android:layout_marginTop="0dp"
                android:background="@drawable/bg_listen_together_chip"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:minWidth="150dp"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingEnd="10dp"
                android:visibility="gone"
                android:elevation="4dp"
                tools:visibility="visible">

                <FrameLayout
                    android:layout_width="42dp"
                    android:layout_height="28dp"
                    android:layout_marginEnd="10dp">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/listenTogetherAvatarFirst"
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:layout_gravity="start|center_vertical"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_pm_icon"
                        app:shapeAppearanceOverlay="@style/CircleShape"
                        app:strokeColor="#40FFFFFF"
                        app:strokeWidth="1dp" />

                    <FrameLayout
                        android:layout_width="30dp"
                        android:layout_height="28dp"
                        android:layout_gravity="end|center_vertical">

                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/listenTogetherAvatarSecond"
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:layout_gravity="center"
                            android:scaleType="centerCrop"
                            android:src="@drawable/ic_pm_icon"
                            app:shapeAppearanceOverlay="@style/CircleShape"
                            app:strokeColor="#40FFFFFF"
                            app:strokeWidth="1dp" />

                        <FrameLayout
                            android:id="@+id/listenTogetherAvatarMoreBadge"
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:layout_gravity="bottom|end"
                            android:background="@drawable/bg_listen_together_avatar_badge"
                            android:padding="3dp"
                            android:translationX="1dp"
                            android:translationY="1dp">

                            <View
                                android:layout_width="4dp"
                                android:layout_height="4dp"
                                android:layout_gravity="center"
                                android:background="@drawable/bg_listen_together_avatar_badge_dot" />
                        </FrameLayout>
                    </FrameLayout>
                </FrameLayout>

                <TextView
                    android:id="@+id/listenTogetherChipPeopleText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:fontFamily="sans-serif"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    tools:text="3人一起听中" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="14dp"
                    android:layout_marginEnd="8dp"
                    android:background="#33FFFFFF" />

                <View
                    android:id="@+id/listenTogetherChipStatusDot"
                    android:layout_width="6dp"
                    android:layout_height="6dp"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/bg_listen_together_status_dot" />

                <TextView
                    android:id="@+id/listenTogetherChipLatencyText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:textColor="#34D399"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    tools:text="23ms" />
            </LinearLayout>
        </FrameLayout>

        <!-- Action Row -->
        <LinearLayout
            android:id="@+id/actionRow"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingVertical="4dp"
            app:layout_constraintBottom_toTopOf="@id/progressBar"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <Space
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/qualityButton"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/playback_quality"
                    android:padding="12dp"
                    android:src="@drawable/ic_audio_quality_24"
                    app:tint="@android:color/white" />

                <ImageButton
                    android:id="@+id/loveButton"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="16dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/like"
                    android:padding="12dp"
                    android:src="@drawable/ic_love_24"
                    app:tint="@android:color/white" />

                <ImageButton
                    android:id="@+id/downloadButton"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="16dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/download"
                    android:padding="12dp"
                    android:src="@drawable/ic_download_24"
                    app:tint="@android:color/white" />



                <ImageButton
                    android:id="@+id/lyricSettingsButton"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="16dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/lyric_settings_button_cd"
                    android:padding="12dp"
                    android:src="@drawable/ic_lyric_setting"
                    app:tint="@android:color/white" />

                <ImageButton
                    android:id="@+id/listenTogetherButton"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="16dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/listen_together_title"
                    android:padding="12dp"
                    android:src="@drawable/ic_listen_together_24"
                    app:tint="@android:color/white" />
            </LinearLayout>

            <Space
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />


        </LinearLayout>

        <!-- Progress Bar -->
        <SeekBar
            android:id="@+id/progressBar"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_marginHorizontal="24dp"
            android:max="100"
            android:progress="0"
            android:progressTint="@android:color/white"
            android:thumbTint="@android:color/white"
            app:layout_constraintBottom_toTopOf="@id/timeLayout"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Time Labels -->
        <LinearLayout
            android:id="@+id/timeLayout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginBottom="8dp"
            android:orientation="horizontal"
            app:layout_constraintBottom_toTopOf="@id/controlsLayout"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <TextView
                android:id="@+id/currentTimeTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textColor="#B0B0B0"
                android:textSize="12sp" />

            <Space
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/totalTimeTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textColor="#B0B0B0"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- 5 Control Buttons -->
        <LinearLayout
            android:id="@+id/controlsLayout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="16dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <ImageButton
                android:id="@+id/repeatButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/refresh"
                android:padding="12dp"
                android:src="@drawable/ic_repeat_24"
                app:tint="@android:color/white" />

            <ImageButton
                android:id="@+id/previousButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/song_name"
                android:padding="12dp"
                android:src="@drawable/ic_previous_24"
                app:tint="@android:color/white" />

            <ImageButton
                android:id="@+id/playPauseButton"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@drawable/bg_play_pause_circle"
                android:contentDescription="@string/now_playing"
                android:padding="14dp"
                android:src="@drawable/ic_pause_24"
                app:tint="#1A1A1A" />

            <ImageButton
                android:id="@+id/nextButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/song_name"
                android:padding="12dp"
                android:src="@drawable/ic_next_24"
                app:tint="@android:color/white" />

            <ImageButton
                android:id="@+id/playListButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/currentPlayList"
                android:padding="12dp"
                android:src="@drawable/ic_playlist_24"
                app:tint="@android:color/white" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- BottomSheet dimOverlay -->
    <View
        android:id="@+id/dimOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone" />

    <!-- BottomSheet -->
    <FrameLayout
        android:id="@+id/standardBottomSheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_bottom_sheet"
        android:elevation="10dp"
        android:visibility="visible"
        app:behavior_fitToContents="true"
        app:behavior_hideable="true"
        app:behavior_skipCollapsed="true"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">

        <include
            android:id="@+id/playlistBottomSheet"
            layout="@layout/bottom_sheet_playlist"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
