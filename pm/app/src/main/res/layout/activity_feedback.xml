<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/feedbackRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/account_profile_page_bg"
    android:fitsSystemWindows="false"
    android:orientation="vertical">

    <View
        android:id="@+id/feedbackStatusBarSpacer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@color/account_profile_page_bg" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="56dp">

        <ImageButton
            android:id="@+id/feedbackBackButton"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_gravity="start|center_vertical"
            android:layout_marginStart="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/feedback_back"
            android:padding="10dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_back_24" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/feedback_title"
            android:textColor="@color/account_profile_value"
            android:textSize="17sp"
            android:textStyle="bold" />
    </FrameLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/feedbackScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="4dp"
            android:paddingBottom="32dp">

            <!-- 反馈类型 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/feedback_section_type"
                    android:textColor="@color/account_profile_value"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="@string/feedback_required_mark"
                    android:textColor="@color/feedback_required_mark"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- 2x2 chip grid -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/feedbackTypeBug"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_feedback_type_chip"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="horizontal"
                    tools:background="@drawable/bg_feedback_type_chip_selected">

                    <ImageView
                        android:id="@+id/feedbackTypeBugIcon"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_feedback_type_bug"
                        app:tint="@color/feedback_chip_default_text" />

                    <TextView
                        android:id="@+id/feedbackTypeBugText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="@string/feedback_type_bug"
                        android:textColor="@color/feedback_chip_default_text"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/feedbackTypeSuggestion"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_feedback_type_chip"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/feedbackTypeSuggestionIcon"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_feedback_type_suggestion"
                        app:tint="@color/feedback_chip_default_text" />

                    <TextView
                        android:id="@+id/feedbackTypeSuggestionText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="@string/feedback_type_suggestion"
                        android:textColor="@color/feedback_chip_default_text"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/feedbackTypeAccount"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_feedback_type_chip"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/feedbackTypeAccountIcon"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_feedback_type_account"
                        app:tint="@color/feedback_chip_default_text" />

                    <TextView
                        android:id="@+id/feedbackTypeAccountText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="@string/feedback_type_account"
                        android:textColor="@color/feedback_chip_default_text"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/feedbackTypeOther"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_feedback_type_chip"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/feedbackTypeOtherIcon"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_feedback_type_other"
                        app:tint="@color/feedback_chip_default_text" />

                    <TextView
                        android:id="@+id/feedbackTypeOtherText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="@string/feedback_type_other"
                        android:textColor="@color/feedback_chip_default_text"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- 问题描述 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/feedback_section_desc"
                    android:textColor="@color/account_profile_value"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="@string/feedback_required_mark"
                    android:textColor="@color/feedback_required_mark"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_listen_together_room_inner_card">

                <EditText
                    android:id="@+id/feedbackDescInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@null"
                    android:gravity="top|start"
                    android:hint="@string/feedback_desc_hint"
                    android:inputType="textMultiLine|textCapSentences"
                    android:maxLength="500"
                    android:minLines="5"
                    android:paddingHorizontal="14dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="34dp"
                    android:textColor="@color/account_profile_value"
                    android:textColorHint="@color/feedback_counter_text"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/feedbackDescCounter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|end"
                    android:layout_marginEnd="14dp"
                    android:layout_marginBottom="10dp"
                    android:textColor="@color/feedback_counter_text"
                    android:textSize="11sp"
                    tools:text="0 / 500" />
            </FrameLayout>

            <!-- 添加图片 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/feedback_section_images"
                    android:textColor="@color/account_profile_value"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="@string/feedback_images_hint"
                    android:textColor="@color/feedback_counter_text"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/feedbackImagesContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal" />

            <!-- 联系方式 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/feedback_section_contact"
                    android:textColor="@color/account_profile_value"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="@string/feedback_contact_optional_hint"
                    android:textColor="@color/feedback_counter_text"
                    android:textSize="12sp" />
            </LinearLayout>

            <EditText
                android:id="@+id/feedbackContactInput"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_listen_together_room_inner_card"
                android:hint="@string/feedback_contact_hint"
                android:imeOptions="actionDone"
                android:inputType="textEmailAddress"
                android:maxLength="64"
                android:paddingHorizontal="14dp"
                android:singleLine="true"
                android:textColor="@color/account_profile_value"
                android:textColorHint="@color/feedback_counter_text"
                android:textSize="14sp" />

            <!-- 提交按钮 -->
            <TextView
                android:id="@+id/feedbackSubmitButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="28dp"
                android:background="@drawable/bg_listen_together_create_button"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="@string/feedback_submit"
                android:textColor="@color/listen_together_create_button_text"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center"
                android:text="@string/feedback_thanks_hint"
                android:textColor="@color/feedback_thanks_text"
                android:textSize="11sp" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
