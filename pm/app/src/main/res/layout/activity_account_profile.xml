<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/accountProfileRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/account_profile_page_bg"
    android:fitsSystemWindows="false"
    android:orientation="vertical">

    <View
        android:id="@+id/accountProfileStatusBarSpacer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@color/account_profile_page_bg" />

    <!-- Header -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="56dp">

        <ImageButton
            android:id="@+id/accountProfileBackButton"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_gravity="start|center_vertical"
            android:layout_marginStart="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/account_profile_back"
            android:padding="10dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_back_24" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/account_profile_title"
            android:textColor="@color/account_profile_value"
            android:textSize="17sp"
            android:textStyle="bold" />
    </FrameLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/accountProfileScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingBottom="32dp">

            <!-- Avatar -->
            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="8dp">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/accountProfileAvatar"
                    android:layout_width="106dp"
                    android:layout_height="106dp"
                    android:padding="10dp"
                    android:background="@color/account_profile_card_bg"
                    android:scaleType="centerCrop"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.Pm.Circular"
                    app:strokeColor="@color/account_profile_card_bg"
                    app:strokeWidth="3dp" />

                <LinearLayout
                    android:id="@+id/accountProfileAvatarChip"
                    android:layout_width="wrap_content"
                    android:layout_height="26dp"
                    android:layout_gravity="bottom|center_horizontal"
                    android:layout_marginBottom="1dp"
                    android:background="@drawable/bg_account_profile_avatar_chip"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:paddingHorizontal="10dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_camera_24"
                        app:tint="@color/account_profile_avatar_chip_text" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="@string/account_profile_avatar_change"
                        android:textColor="@color/account_profile_avatar_chip_text"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </FrameLayout>

            <!-- 卡片组 1：昵称 + 绑定邮箱 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:background="@drawable/bg_account_profile_card"
                android:orientation="vertical"
                android:paddingHorizontal="18dp">

                <LinearLayout
                    android:id="@+id/accountProfileUsernameRow"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/account_profile_label_username"
                        android:textColor="@color/account_profile_label"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/accountProfileUsernameValue"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:ellipsize="end"
                        android:gravity="end"
                        android:maxLines="1"
                        android:textColor="@color/account_profile_value"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        tools:text="i_忆昔" />

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginStart="4dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_chevron_right_24"
                        app:tint="@color/account_profile_chevron_tint" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/accountProfileEmailRow"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/account_profile_label_email"
                        android:textColor="@color/account_profile_label"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/accountProfileEmailValue"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:ellipsize="end"
                        android:gravity="end"
                        android:maxLines="1"
                        android:textColor="@color/account_profile_value"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        tools:text="emily.design@pisa.com" />

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginStart="4dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_chevron_right_24"
                        app:tint="@color/account_profile_chevron_tint" />
                </LinearLayout>
            </LinearLayout>

            <!-- 卡片组 2：账号信息 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_account_profile_card"
                android:orientation="vertical"
                android:paddingHorizontal="18dp">

                <LinearLayout
                    android:id="@+id/accountProfileIdRow"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/account_profile_label_id"
                        android:textColor="@color/account_profile_label"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/accountProfileIdValue"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:ellipsize="end"
                        android:gravity="end"
                        android:maxLines="1"
                        android:textColor="@color/account_profile_value"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        tools:text="549090146" />

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginStart="6dp"
                        android:contentDescription="@string/account_profile_copy_id"
                        android:src="@drawable/ic_copy_24"
                        app:tint="@color/account_profile_chevron_tint" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/account_profile_label_created_at"
                        android:textColor="@color/account_profile_label"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/accountProfileCreatedAtValue"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:ellipsize="end"
                        android:gravity="end"
                        android:maxLines="1"
                        android:textColor="@color/account_profile_label"
                        android:textSize="14sp"
                        tools:text="2017年07月12日" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/account_profile_label_last_login"
                        android:textColor="@color/account_profile_label"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/accountProfileLastLoginValue"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:ellipsize="end"
                        android:gravity="end"
                        android:maxLines="1"
                        android:textColor="@color/account_profile_label"
                        android:textSize="14sp"
                        tools:text="2026年06月05日 00:02" />
                </LinearLayout>
            </LinearLayout>

            <!-- 卡片组 3：统计 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_account_profile_card"
                android:orientation="vertical"
                android:paddingHorizontal="18dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/account_profile_label_love_count"
                        android:textColor="@color/account_profile_label"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/accountProfileLoveCountValue"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:gravity="end"
                        android:textColor="@color/account_profile_value"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        tools:text="1,248 首" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/account_profile_label_collected_playlists"
                        android:textColor="@color/account_profile_label"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/accountProfileCollectedPlaylistsValue"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:gravity="end"
                        android:textColor="@color/account_profile_value"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        tools:text="32 个" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/account_profile_label_local_playlists"
                        android:textColor="@color/account_profile_label"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/accountProfileLocalPlaylistsValue"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:gravity="end"
                        android:textColor="@color/account_profile_value"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        tools:text="8 个" />
                </LinearLayout>
            </LinearLayout>

            <!-- 保存更改按钮 -->
            <TextView
                android:id="@+id/accountProfileSaveButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="28dp"
                android:background="@drawable/bg_listen_together_create_button"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="@string/account_profile_save"
                android:textColor="@color/listen_together_create_button_text"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- 退出登录 -->
            <TextView
                android:id="@+id/accountProfileLogoutButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="14dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="@string/account_profile_logout"
                android:textColor="@color/account_profile_logout_text"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
