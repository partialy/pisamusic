<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_radius_sheet"
    android:orientation="vertical"
    android:paddingTop="20dp">

    <WebView
        android:id="@+id/announcementWebView"
        android:layout_width="match_parent"
        android:layout_height="320dp"
        android:layout_marginHorizontal="16dp"
        android:overScrollMode="ifContentScrolls"
        android:scrollbarStyle="outsideInset"
        tools:ignore="WebViewLayout" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="28dp"
        android:paddingVertical="16dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/gotoButton"
            style="@style/Widget.Material3.Button"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:text="前往查看"
            android:textColor="@color/action_primary_text"
            android:textStyle="bold"
            android:visibility="gone"
            app:backgroundTint="?attr/colorPrimary"
            app:cornerRadius="25dp" />

        <Space
            android:id="@+id/buttonSpacer"
            android:layout_width="14dp"
            android:layout_height="1dp"
            android:visibility="gone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/confirmButton"
            style="@style/Widget.Material3.Button"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:text="我知道了（剩余0条）"
            android:textColor="@color/action_secondary_text"
            android:textStyle="bold"
            app:backgroundTint="@color/action_secondary_background"
            app:cornerRadius="25dp" />
    </LinearLayout>
</LinearLayout>
