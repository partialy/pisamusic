<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginTop="12dp"
    app:cardBackgroundColor="@color/home_mini_player_bg"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/cache_card_stroke"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/categoryTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                android:textColor="?android:attr/textColorPrimary"
                tools:text="歌曲缓存" />

            <ImageView
                android:id="@+id/categoryInfoIcon"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_marginEnd="4dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_info_24"
                app:tint="?android:attr/textColorSecondary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnClean"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:minWidth="0dp"
                android:paddingHorizontal="16dp"
                android:text="@string/cache_action_clean"
                android:textColor="@color/white"
                app:backgroundTint="@color/cache_clean_button_bg"
                app:cornerRadius="20dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnManage"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:minWidth="0dp"
                android:paddingHorizontal="14dp"
                android:text="@string/cache_action_manage"
                android:visibility="gone"
                app:cornerRadius="20dp"
                app:strokeColor="@color/cache_clean_button_bg"
                android:textColor="@color/cache_clean_button_bg"
                tools:visibility="visible" />
        </LinearLayout>

        <TextView
            android:id="@+id/categorySizeText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
            android:textColor="?android:attr/textColorPrimary"
            android:textStyle="bold"
            tools:text="2.75 GB" />

        <TextView
            android:id="@+id/categoryExtraText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
            android:textColor="?android:attr/textColorSecondary"
            android:visibility="gone"
            tools:text="(142 首)"
            tools:visibility="visible" />

        <TextView
            android:id="@+id/categoryDescText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:lineSpacingMultiplier="1.15"
            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
            android:textColor="?android:attr/textColorSecondary"
            tools:text="说明文案" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
