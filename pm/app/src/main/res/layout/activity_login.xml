<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/accountLoginRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_account_login_gradient"
    tools:context=".activity.LoginActivity">

    <TextView
        android:id="@+id/accountLoginBackButton"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="36dp"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:gravity="center"
        android:text="&lt;"
        android:textColor="@color/account_login_text_primary"
        android:textSize="34sp"
        android:textStyle="bold"
        android:contentDescription="@string/account_login_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/accountLoginPanel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toTopOf="@id/accountLoginMethodLayout"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/accountLoginBackButton"
        app:layout_constraintVertical_bias="0.43">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <FrameLayout
                android:layout_width="66dp"
                android:layout_height="66dp"
                android:background="@drawable/bg_account_login_icon_holder"
                android:elevation="4dp">

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_pm_icon" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/accountLoginTitleText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/account_login_password_title"
                    android:textColor="@color/account_login_text_primary"
                    android:textSize="30sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="7dp"
                    android:text="@string/account_login_subtitle"
                    android:textColor="@color/account_login_text_secondary"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>

        <EditText
            android:id="@+id/accountLoginIdentifierEditText"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="36dp"
            android:background="@drawable/bg_account_login_field"
            android:hint="@string/account_login_identifier_hint"
            android:imeOptions="actionNext"
            android:inputType="text"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:singleLine="true"
            android:textColor="@color/account_login_text_primary"
            android:textColorHint="@color/account_login_text_hint"
            android:textSize="15sp" />

        <EditText
            android:id="@+id/accountLoginPasswordEditText"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_account_login_field"
            android:hint="@string/account_login_password_hint"
            android:imeOptions="actionDone"
            android:inputType="textPassword"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:singleLine="true"
            android:textColor="@color/account_login_text_primary"
            android:textColorHint="@color/account_login_text_hint"
            android:textSize="15sp" />

        <LinearLayout
            android:id="@+id/accountLoginCodeRow"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:visibility="gone"
            tools:visibility="visible">

            <EditText
                android:id="@+id/accountLoginCodeEditText"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/bg_account_login_field"
                android:hint="@string/account_login_code_hint"
                android:imeOptions="actionDone"
                android:inputType="number"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:singleLine="true"
                android:textColor="@color/account_login_text_primary"
                android:textColorHint="@color/account_login_text_hint"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/accountLoginSendCodeButton"
                android:layout_width="104dp"
                android:layout_height="match_parent"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_account_login_field"
                android:gravity="center"
                android:text="@string/account_login_send_code"
                android:textColor="@color/account_login_brand"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/accountLoginSubmitButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_account_login_primary_button"
            android:gravity="center"
            android:text="@string/account_login_submit"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/accountLoginRegisterButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:gravity="center"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:text="@string/account_login_register"
                android:textColor="@color/account_login_brand"
                android:textSize="14sp"
                android:textStyle="bold" />

            <View
                android:layout_width="1dp"
                android:layout_height="12dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:background="@color/account_login_divider" />

            <TextView
                android:id="@+id/accountLoginResetButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:gravity="center"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:text="@string/account_login_reset_password"
                android:textColor="@color/account_login_brand"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/accountLoginMethodLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="46dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="@color/account_login_divider" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="@string/account_login_method_label"
                android:textColor="@color/account_login_text_secondary"
                android:textSize="12sp"
                android:textStyle="bold" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="@color/account_login_divider" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/accountLoginPhoneModeButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_account_login_method_button"
                android:contentDescription="@string/account_login_phone_method"
                android:padding="13dp"
                android:scaleType="center"
                android:src="@drawable/ic_login_phone_24"
                app:tint="@color/account_login_text_secondary" />

            <ImageButton
                android:id="@+id/accountLoginEmailModeButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:background="@drawable/bg_account_login_method_button"
                android:contentDescription="@string/account_login_email_method"
                android:padding="13dp"
                android:scaleType="center"
                android:src="@drawable/ic_login_email_24"
                app:tint="@color/account_login_text_secondary" />

            <ImageButton
                android:id="@+id/accountLoginPasswordModeButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_account_login_method_button_selected"
                android:contentDescription="@string/account_login_password_method"
                android:padding="13dp"
                android:scaleType="center"
                android:src="@drawable/ic_login_lock_24"
                app:tint="@color/account_login_brand" />
        </LinearLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
