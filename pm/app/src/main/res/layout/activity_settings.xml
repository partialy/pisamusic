<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/settings_page_background"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/settings_page_background"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/settings_page_background"
            app:navigationIcon="@drawable/ic_back_24"
            app:title="@string/settings" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/settings_page_background"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:orientation="vertical"
            android:paddingTop="8dp"
            android:paddingBottom="24dp">

            <!-- 下载与文件 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/home_mini_player_bg"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/settings_card_inset_divider"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <include
                        android:id="@+id/downloadLocation"
                        layout="@layout/item_settings_row" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="50dp"
                        android:background="@color/settings_card_inset_divider" />

                    <include
                        android:id="@+id/fileNamingRule"
                        layout="@layout/item_settings_row" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 元数据写入 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/home_mini_player_bg"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/settings_card_inset_divider"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <include
                        android:id="@+id/writeCover"
                        layout="@layout/item_settings_switch" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="50dp"
                        android:background="@color/settings_card_inset_divider" />

                    <include
                        android:id="@+id/writeTags"
                        layout="@layout/item_settings_switch" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="50dp"
                        android:background="@color/settings_card_inset_divider" />

                    <include
                        android:id="@+id/writeLyrics"
                        layout="@layout/item_settings_switch" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 外观 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/home_mini_player_bg"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/settings_card_inset_divider"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <include
                        android:id="@+id/themeMode"
                        layout="@layout/item_settings_row" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="50dp"
                        android:background="@color/settings_card_inset_divider" />

                    <include
                        android:id="@+id/lyricColorPresets"
                        layout="@layout/item_settings_row" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 数据与调试 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/home_mini_player_bg"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/settings_card_inset_divider"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <include
                        android:id="@+id/dataManagement"
                        layout="@layout/item_settings_row" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="50dp"
                        android:background="@color/settings_card_inset_divider" />

                    <include
                        android:id="@+id/cacheManagement"
                        layout="@layout/item_settings_row" />

                    <View
                        android:id="@+id/devDebugDivider"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="50dp"
                        android:background="@color/settings_card_inset_divider" />

                    <include
                        android:id="@+id/devDebugEntry"
                        layout="@layout/item_settings_row" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 公告与关于 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/home_mini_player_bg"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/settings_card_inset_divider"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <include
                        android:id="@+id/feedbackEntry"
                        layout="@layout/item_settings_row" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="50dp"
                        android:background="@color/settings_card_inset_divider" />

                    <include
                        android:id="@+id/announcementEntry"
                        layout="@layout/item_settings_row" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="50dp"
                        android:background="@color/settings_card_inset_divider" />

                    <include
                        android:id="@+id/checkUpdateEntry"
                        layout="@layout/item_settings_row" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="50dp"
                        android:background="@color/settings_card_inset_divider" />

                    <include
                        android:id="@+id/aboutEntry"
                        layout="@layout/item_settings_row" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/deviceIdLabelTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:clickable="true"
                android:ellipsize="middle"
                android:focusable="true"
                android:gravity="center"
                android:maxLines="1"
                android:paddingHorizontal="12dp"
                android:textColor="@color/home_mini_player_subtitle"
                android:textSize="11sp" />
        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
