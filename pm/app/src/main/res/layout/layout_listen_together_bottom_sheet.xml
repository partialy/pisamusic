<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet"
    android:fillViewport="false">

    <LinearLayout
        android:id="@+id/listenTogetherRoot"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="22dp"
        android:paddingBottom="28dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/listenTogetherTitleView"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/listen_together_title"
                android:textAppearance="@style/TextAppearance.Material3.TitleLarge"
                android:textColor="?attr/colorOnSurface"
                android:textStyle="bold"
                app:layout_constraintEnd_toStartOf="@id/listenTogetherCloseButton"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageButton
                android:id="@+id/listenTogetherCloseButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/cancel"
                android:padding="8dp"
                android:src="@drawable/ic_close_24dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="?attr/colorOnSurfaceVariant" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <TextView
            android:id="@+id/listenTogetherSubtitleView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/listen_together_subtitle"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
            android:textColor="?attr/colorOnSurfaceVariant" />

        <LinearLayout
            android:id="@+id/listenTogetherIdleGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="vertical">

            <!-- 房间名称 -->
            <LinearLayout
                android:id="@+id/listenTogetherRoomNameRow"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:background="@drawable/bg_listen_together_create_card"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/listen_together_room_name_label"
                    android:textColor="@color/listen_together_field_label"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/listenTogetherRoomNameInput"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:background="@null"
                    android:gravity="end|center_vertical"
                    android:imeOptions="actionDone"
                    android:inputType="text"
                    android:maxLength="16"
                    android:paddingHorizontal="0dp"
                    android:singleLine="true"
                    android:textColor="@color/listen_together_field_value"
                    android:textColorHint="@color/listen_together_field_label"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    tools:text="张三的音乐房" />
            </LinearLayout>

            <!-- 房间号 -->
            <LinearLayout
                android:id="@+id/listenTogetherRoomIdRow"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_listen_together_create_card"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/listen_together_room_id_label"
                    android:textColor="@color/listen_together_field_label"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="@string/listen_together_room_id_suffix"
                    android:textColor="@color/listen_together_field_label"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/listenTogetherRoomIdInput"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:background="@null"
                    android:gravity="end|center_vertical"
                    android:imeOptions="actionDone"
                    android:inputType="number"
                    android:maxLength="8"
                    android:paddingHorizontal="0dp"
                    android:singleLine="true"
                    android:textColor="@color/listen_together_field_value"
                    android:textColorHint="@color/listen_together_field_label"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    tools:text="123456" />
            </LinearLayout>

            <!-- 最大人数 + 成员控制切歌 -->
            <LinearLayout
                android:id="@+id/listenTogetherCreateOptionsRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <!-- 最大人数 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_listen_together_create_card"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="14dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/listen_together_max_people_label"
                            android:textColor="@color/listen_together_field_label"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/listenTogetherMaxPeopleValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:textColor="@color/listen_together_field_value"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            tools:text="2 人" />
                    </LinearLayout>

                    <ImageButton
                        android:id="@+id/listenTogetherMaxPeopleMinus"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:background="@drawable/bg_listen_together_stepper_circle"
                        android:contentDescription="@string/listen_together_max_people_label"
                        android:padding="6dp"
                        android:scaleType="fitCenter"
                        android:src="@drawable/ic_stepper_minus_24" />

                    <ImageButton
                        android:id="@+id/listenTogetherMaxPeoplePlus"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_listen_together_stepper_circle"
                        android:contentDescription="@string/listen_together_max_people_label"
                        android:padding="6dp"
                        android:scaleType="fitCenter"
                        android:src="@drawable/ic_stepper_plus_24" />
                </LinearLayout>

                <!-- 成员控制切歌 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_listen_together_create_card"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="14dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/listen_together_member_op_short"
                            android:textColor="@color/listen_together_field_label"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/listenTogetherMemberOperationStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:textColor="@color/listen_together_field_value"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            tools:text="已开启" />
                    </LinearLayout>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/listenTogetherMemberOperationSwitchCreate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>
            </LinearLayout>

            <!-- 创建房间 + 扫码加入 同一行 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/listenTogetherCreateButton"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_listen_together_create_button"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="@string/listen_together_create_room"
                    android:textColor="@color/listen_together_create_button_text"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/listenTogetherScanJoinButton"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_listen_together_create_card"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_qr_scan_24"
                        app:tint="@color/listen_together_field_value" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="@string/listen_together_scan_join"
                        android:textColor="@color/listen_together_field_value"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- 邀请码 + 加入 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/listenTogetherRoomInput"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_listen_together_pill_input"
                    android:hint="@string/listen_together_invite_hint"
                    android:imeOptions="actionDone"
                    android:inputType="number"
                    android:maxLength="8"
                    android:paddingHorizontal="18dp"
                    android:singleLine="true"
                    android:textColor="@color/listen_together_field_value"
                    android:textColorHint="@color/listen_together_field_label"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/listenTogetherJoinButton"
                    android:layout_width="80dp"
                    android:layout_height="52dp"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/bg_listen_together_join_button"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="@string/listen_together_join_room"
                    android:textColor="@color/listen_together_join_button_text"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- 底部当前歌曲卡片 -->
            <LinearLayout
                android:id="@+id/listenTogetherCurrentSongCard"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_listen_together_create_card"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/listenTogetherCurrentSongCover"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="#33808080"
                    android:scaleType="centerCrop"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.Pm.Corner12" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/listenTogetherCurrentSongName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:textColor="@color/listen_together_field_value"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        tools:text="歌名" />

                    <TextView
                        android:id="@+id/listenTogetherCurrentSongArtist"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:textColor="@color/listen_together_field_label"
                        android:textSize="12sp"
                        tools:text="歌手" />
                </LinearLayout>

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_marginEnd="4dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_listen_together_equalizer" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/listenTogetherRoomGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="vertical"
            android:visibility="gone"
            tools:visibility="visible">

            <TextView
                android:id="@+id/listenTogetherRoomInfoView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
                android:textColor="?attr/colorOnSurface"
                android:textStyle="bold"
                tools:text="房间 123456 · 2 人在线" />

            <TextView
                android:id="@+id/listenTogetherSyncStatusView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                android:textColor="?attr/colorOnSurfaceVariant"
                tools:text="同步正常 · 仅房主控制" />

            <TextView
                android:id="@+id/listenTogetherCurrentPlayingLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="当前播放"
                android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
                android:textColor="?attr/colorOnSurfaceVariant" />

            <TextView
                android:id="@+id/listenTogetherRoomSongView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:ellipsize="end"
                android:maxLines="2"
                android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
                android:textColor="?attr/colorOnSurface"
                tools:text="歌曲名 - 歌手" />

            <TextView
                android:id="@+id/listenTogetherMembersLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="成员"
                android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
                android:textColor="?attr/colorOnSurfaceVariant" />

            <TextView
                android:id="@+id/listenTogetherMembersView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                android:textColor="?attr/colorOnSurfaceVariant"
                tools:text="我 房主   小明" />

            <TextView
                android:id="@+id/listenTogetherPermissionLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="@string/listen_together_member_permission"
                android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
                android:textColor="?attr/colorOnSurfaceVariant" />

            <LinearLayout
                android:id="@+id/listenTogetherPermissionRow"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/listenTogetherPermissionText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/listen_together_member_can_control"
                    android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
                    android:textColor="?attr/colorOnSurface" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/listenTogetherMemberOperationSwitch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <TextView
                android:id="@+id/listenTogetherInviteLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="邀请朋友"
                android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
                android:textColor="?attr/colorOnSurfaceVariant" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/listenTogetherCopyButton"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="@string/listen_together_copy_room"
                    app:icon="@drawable/ic_copy_24" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/listenTogetherShareButton"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:enabled="false"
                    android:text="@string/listen_together_share_room"
                    app:icon="@drawable/ic_share_24" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/listenTogetherQrButton"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:enabled="false"
                    android:text="@string/listen_together_qr_placeholder"
                    app:icon="@drawable/ic_qr_scan_24" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/listenTogetherLeaveButton"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:text="@string/listen_together_leave_room"
                android:textColor="@color/red" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
