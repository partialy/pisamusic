<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet"
    android:fillViewport="false">

    <LinearLayout
        android:id="@+id/listenTogetherRoot"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="22dp"
        android:paddingBottom="28dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/listenTogetherTitleView"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/listen_together_title"
                android:textAppearance="@style/TextAppearance.Material3.TitleLarge"
                android:textColor="?attr/colorOnSurface"
                android:textStyle="bold"
                app:layout_constraintEnd_toStartOf="@id/listenTogetherCloseButton"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageButton
                android:id="@+id/listenTogetherCloseButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/cancel"
                android:padding="8dp"
                android:src="@drawable/ic_close_24dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="?attr/colorOnSurfaceVariant" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <TextView
            android:id="@+id/listenTogetherSubtitleView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/listen_together_subtitle"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
            android:textColor="?attr/colorOnSurfaceVariant" />

        <LinearLayout
            android:id="@+id/listenTogetherIdleGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="vertical">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/listenTogetherRoomNameLayout"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/listen_together_room_name_label"
                android:textColorHint="@color/account_login_text_hint"
                app:boxBackgroundColor="@color/account_login_field_bg"
                app:boxCornerRadiusBottomEnd="18dp"
                app:boxCornerRadiusBottomStart="18dp"
                app:boxCornerRadiusTopEnd="18dp"
                app:boxCornerRadiusTopStart="18dp"
                app:boxStrokeColor="@color/account_text_input_stroke"
                app:hintTextColor="@color/account_text_input_stroke"
                tools:placeholderText="张三的音乐房">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/listenTogetherRoomNameInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:imeOptions="actionDone"
                    android:inputType="text"
                    android:maxLength="16"
                    android:singleLine="true"
                    android:textColor="@color/listen_together_field_value"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    tools:text="张三的音乐房" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/listenTogetherRoomIdLayout"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:hint="@string/listen_together_room_id_label"
                android:textColorHint="@color/account_login_text_hint"
                app:boxBackgroundColor="@color/account_login_field_bg"
                app:boxCornerRadiusBottomEnd="18dp"
                app:boxCornerRadiusBottomStart="18dp"
                app:boxCornerRadiusTopEnd="18dp"
                app:boxCornerRadiusTopStart="18dp"
                app:boxStrokeColor="@color/account_text_input_stroke"
                app:helperText="@string/listen_together_room_id_suffix"
                app:helperTextTextColor="@color/listen_together_field_label"
                app:hintTextColor="@color/account_text_input_stroke">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/listenTogetherRoomIdInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:imeOptions="actionDone"
                    android:inputType="number"
                    android:maxLength="8"
                    android:singleLine="true"
                    android:textColor="@color/listen_together_field_value"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    tools:text="123456" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- 最大人数 + 成员控制切歌 -->
            <LinearLayout
                android:id="@+id/listenTogetherCreateOptionsRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <!-- 最大人数 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_listen_together_create_card"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="14dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/listen_together_max_people_label"
                            android:textColor="@color/listen_together_field_label"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/listenTogetherMaxPeopleValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:textColor="@color/listen_together_field_value"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            tools:text="2 人" />
                    </LinearLayout>

                    <ImageButton
                        android:id="@+id/listenTogetherMaxPeopleMinus"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:background="@drawable/bg_listen_together_stepper_circle"
                        android:contentDescription="@string/listen_together_max_people_label"
                        android:padding="6dp"
                        android:scaleType="fitCenter"
                        android:src="@drawable/ic_stepper_minus_24" />

                    <ImageButton
                        android:id="@+id/listenTogetherMaxPeoplePlus"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_listen_together_stepper_circle"
                        android:contentDescription="@string/listen_together_max_people_label"
                        android:padding="6dp"
                        android:scaleType="fitCenter"
                        android:src="@drawable/ic_stepper_plus_24" />
                </LinearLayout>

                <!-- 成员控制切歌 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_listen_together_create_card"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="14dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/listen_together_member_op_short"
                            android:textColor="@color/listen_together_field_label"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/listenTogetherMemberOperationStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:textColor="@color/listen_together_field_value"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            tools:text="已开启" />
                    </LinearLayout>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/listenTogetherMemberOperationSwitchCreate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>
            </LinearLayout>

            <!-- 创建房间 + 扫码加入 同一行 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/listenTogetherCreateButton"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_listen_together_create_button"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="@string/listen_together_create_room"
                    android:textColor="@color/listen_together_create_button_text"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/listenTogetherScanJoinButton"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_listen_together_create_card"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_qr_scan_24"
                        app:tint="@color/listen_together_field_value" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="@string/listen_together_scan_join"
                        android:textColor="@color/listen_together_field_value"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- 邀请码 + 加入 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/listenTogetherRoomInputLayout"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="@string/listen_together_invite_hint"
                    android:textColorHint="@color/account_login_text_hint"
                    app:boxBackgroundColor="@color/account_login_field_bg"
                    app:boxCornerRadiusBottomEnd="18dp"
                    app:boxCornerRadiusBottomStart="18dp"
                    app:boxCornerRadiusTopEnd="18dp"
                    app:boxCornerRadiusTopStart="18dp"
                    app:boxStrokeColor="@color/account_text_input_stroke"
                    app:hintTextColor="@color/account_text_input_stroke">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/listenTogetherRoomInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:imeOptions="actionDone"
                        android:inputType="number"
                        android:maxLength="8"
                        android:singleLine="true"
                        android:textColor="@color/listen_together_field_value"
                        android:textSize="14sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:id="@+id/listenTogetherJoinButton"
                    android:layout_width="80dp"
                    android:layout_height="56dp"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/bg_listen_together_join_button"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="@string/listen_together_join_room"
                    android:textColor="@color/listen_together_join_button_text"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- 底部当前歌曲卡片 -->
            <LinearLayout
                android:id="@+id/listenTogetherCurrentSongCard"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_listen_together_create_card"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/listenTogetherCurrentSongCover"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="#33808080"
                    android:scaleType="centerCrop"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.Pm.Corner12" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/listenTogetherCurrentSongName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:textColor="@color/listen_together_field_value"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        tools:text="歌名" />

                    <TextView
                        android:id="@+id/listenTogetherCurrentSongArtist"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:textColor="@color/listen_together_field_label"
                        android:textSize="12sp"
                        tools:text="歌手" />
                </LinearLayout>

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_marginEnd="4dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_listen_together_equalizer" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/listenTogetherRoomGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="vertical"
            android:visibility="gone"
            tools:visibility="visible">

            <TextView
                android:id="@+id/listenTogetherRoomInfoView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/listen_together_section_label"
                android:textSize="13sp"
                tools:text="房间 8K42Q · 3 人在线" />

            <!-- 当前同步 -->
            <TextView
                android:id="@+id/listenTogetherCurrentPlayingLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:letterSpacing="0.05"
                android:text="@string/listen_together_section_now_playing"
                android:textColor="@color/listen_together_section_label"
                android:textSize="12sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_listen_together_room_inner_card"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="12dp">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/listenTogetherRoomSongCover"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_listen_together_room_song_cover"
                    android:scaleType="centerCrop"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.Pm.Corner12" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/listenTogetherRoomSongView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:textColor="@color/listen_together_field_value"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        tools:text="歌名" />

                    <TextView
                        android:id="@+id/listenTogetherRoomSongArtist"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:textColor="@color/listen_together_section_label"
                        android:textSize="12sp"
                        tools:text="歌手" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:gravity="end"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/listenTogetherRoomPositionView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="monospace"
                        android:textColor="@color/listen_together_position_text"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        tools:text="02:13 / 04:20" />

                    <LinearLayout
                        android:id="@+id/listenTogetherLatencyBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:background="@drawable/bg_listen_together_latency_badge"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="6dp"
                        android:paddingVertical="2dp">

                        <View
                            android:layout_width="4dp"
                            android:layout_height="4dp"
                            android:background="@drawable/bg_listen_together_latency_dot" />

                        <TextView
                            android:id="@+id/listenTogetherLatencyView"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:fontFamily="monospace"
                            android:textColor="@color/listen_together_latency_text"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            tools:text="23ms" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- 成员 -->
            <TextView
                android:id="@+id/listenTogetherMembersLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:letterSpacing="0.05"
                android:text="@string/listen_together_section_members"
                android:textColor="@color/listen_together_section_label"
                android:textSize="12sp"
                android:textStyle="bold" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:overScrollMode="never"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/listenTogetherMembersView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" />
            </HorizontalScrollView>

            <!-- 邀请朋友 -->
            <TextView
                android:id="@+id/listenTogetherInviteLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:letterSpacing="0.05"
                android:text="@string/listen_together_section_invite"
                android:textColor="@color/listen_together_section_label"
                android:textSize="12sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <FrameLayout
                    android:id="@+id/listenTogetherCopyButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_listen_together_invite_icon_button"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:contentDescription="@string/listen_together_copy_room"
                        android:src="@drawable/ic_copy_24"
                        app:tint="@color/listen_together_invite_button_icon" />
                </FrameLayout>

                <FrameLayout
                    android:id="@+id/listenTogetherShareButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_listen_together_invite_icon_button"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:contentDescription="@string/listen_together_share_room"
                        android:src="@drawable/ic_share_24"
                        app:tint="@color/listen_together_invite_button_icon" />
                </FrameLayout>

                <FrameLayout
                    android:id="@+id/listenTogetherQrButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_listen_together_invite_icon_button"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:contentDescription="@string/listen_together_qr_placeholder"
                        android:src="@drawable/ic_qr_scan_24"
                        app:tint="@color/listen_together_invite_button_icon" />
                </FrameLayout>
            </LinearLayout>

            <!-- 播放权限 -->
            <TextView
                android:id="@+id/listenTogetherPermissionLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:letterSpacing="0.05"
                android:text="@string/listen_together_section_permission"
                android:textColor="@color/listen_together_section_label"
                android:textSize="12sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/listenTogetherPermissionRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_listen_together_room_inner_card"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="14dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/listenTogetherPermissionText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/listen_together_member_permission"
                        android:textColor="@color/listen_together_field_value"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/listen_together_permission_subtitle"
                        android:textColor="@color/listen_together_section_label"
                        android:textSize="12sp" />
                </LinearLayout>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/listenTogetherMemberOperationSwitch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="18dp"
                android:background="@color/listen_together_divider" />

            <TextView
                android:id="@+id/listenTogetherLeaveButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_listen_together_leave_button"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:letterSpacing="0.05"
                android:text="@string/listen_together_leave_room"
                android:textColor="@color/listen_together_leave_text"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/listenTogetherSyncStatusView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:textColor="@color/listen_together_section_label"
                android:textSize="11sp"
                tools:text="同步正常 · 仅房主控制" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
