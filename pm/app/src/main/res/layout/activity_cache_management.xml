<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cacheManagementRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/home_page_bg"
    android:fitsSystemWindows="false"
    android:orientation="vertical">

    <View
        android:id="@+id/cacheStatusBarSpacer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@color/home_page_bg" />

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/home_page_bg"
            app:navigationIcon="@drawable/ic_back_24"
            app:title="@string/settings_cache_management" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/cacheScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="8dp"
                app:cardBackgroundColor="@color/home_mini_player_bg"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/cache_card_stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/usageLabelText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/cache_usage_app_label"
                        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                        android:textColor="?android:attr/textColorSecondary" />

                    <TextView
                        android:id="@+id/usageTotalText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:textAppearance="@style/TextAppearance.Material3.DisplaySmall"
                        android:textColor="?android:attr/textColorPrimary"
                        android:textStyle="bold"
                        tools:text="1.25 GB" />

                    <TextView
                        android:id="@+id/phoneTotalStorageText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                        android:textColor="?android:attr/textColorSecondary"
                        tools:text="手机总容量 256.00 GB" />

                    <TextView
                        android:id="@+id/usagePercentText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
                        android:textColor="?android:attr/textColorSecondary"
                        tools:text="占手机存储 2%" />

                    <LinearLayout
                        android:id="@+id/usageBar"
                        android:layout_width="match_parent"
                        android:layout_height="6dp"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">

                        <View
                            android:id="@+id/usageBarApp"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@color/cache_usage_bar_app" />

                        <View
                            android:id="@+id/usageBarPhoneUsed"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@color/cache_usage_bar_phone_used" />

                        <View
                            android:id="@+id/usageBarFree"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@color/cache_usage_bar_free" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/legendAppText"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                            android:textColor="?android:attr/textColorSecondary"
                            tools:text="● Pisa Music 2%" />

                        <TextView
                            android:id="@+id/legendPhoneUsedText"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center_horizontal"
                            android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                            android:textColor="?android:attr/textColorSecondary"
                            tools:text="● 手机已用" />

                        <TextView
                            android:id="@+id/legendFreeText"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="end"
                            android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                            android:textColor="?android:attr/textColorSecondary"
                            tools:text="● 手机可用" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <include
                android:id="@+id/cardSongCache"
                layout="@layout/include_cache_category_card" />

            <include
                android:id="@+id/cardLyricCache"
                layout="@layout/include_cache_category_card" />

            <include
                android:id="@+id/cardDownloaded"
                layout="@layout/include_cache_category_card" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
