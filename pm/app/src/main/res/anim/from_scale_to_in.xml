<?xml version="1.0" encoding="utf-8"?>
<set xmlns:android="http://schemas.android.com/apk/res/android"
    android:duration="1000">

    <scale
        android:fromXScale="2"
        android:fromYScale="2"
        android:toXScale="1"
        android:toYScale="1"
        android:pivotX="50%"
        android:pivotY="50%" />

    <!-- 透明度动画 -->
    <alpha
        android:fromAlpha="0.8"
        android:toAlpha="1" />
</set>